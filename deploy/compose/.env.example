# Copy to `.env` (podman-compose / docker compose read it automatically) and
# adjust as needed. `.env` is git-ignored; this `.example` is the committed
# template.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
# These three are consumed by the `postgres` container's official entrypoint
# AND interpolated into the assistant's DATABASE_URL below. Keep them in sync.
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant-dev-password
POSTGRES_DB=desktop_assistant

# ---------------------------------------------------------------------------
# Ollama (the default, credential-free LLM connection)
# ---------------------------------------------------------------------------
# Where the assistant container reaches a host-side Ollama. On podman the host
# is reachable as `host.containers.internal`; on Docker Desktop it is
# `host.docker.internal`. If you run Ollama in this same compose network
# instead, point this at that service name (e.g. http://ollama:11434).
OLLAMA_BASE_URL=http://host.containers.internal:11434

# The chat model the `interactive` purpose uses. Must be pulled in your Ollama
# (`ollama pull llama3.2`). Backend purposes (titling/dreaming) inherit it.
OLLAMA_CHAT_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Dex (OIDC) — static client + dev user
# ---------------------------------------------------------------------------
# Must match `staticClients[0].secret` in dex-config.yaml.
DEX_CLIENT_SECRET=desktop-assistant-dev-secret
