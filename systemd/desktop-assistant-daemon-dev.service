[Unit]
Description=Desktop Assistant Backend Daemon (Development)
After=default.target

[Service]
Type=dbus
BusName=org.desktopAssistant.Dev
ExecStart=%h/.cargo/bin/desktop-assistant-daemon
Restart=on-failure
RestartSec=2
Environment=RUST_LOG=info
Environment=DESKTOP_ASSISTANT_DBUS_SERVICE=org.desktopAssistant.Dev

[Install]
WantedBy=default.target
