pkgname=desktop-assistant
pkgver=0.1.0
pkgrel=1
pkgdesc="Desktop assistant daemon and terminal UI with D-Bus API"
arch=('x86_64' 'aarch64')
url="https://example.com/desktop-assistant"
license=('MIT')
depends=('dbus' 'systemd')
makedepends=('cargo' 'rust')
source=("${pkgname}-${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  cargo build --release --workspace
}

check() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  cargo test --workspace --release --locked
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  install -Dm755 target/release/desktop-assistant-daemon "${pkgdir}/usr/bin/desktop-assistant-daemon"
  install -Dm755 target/release/desktop-assistant-tui "${pkgdir}/usr/bin/desktop-assistant-tui"

  install -Dm644 systemd/desktop-assistant-daemon.service \
    "${pkgdir}/usr/lib/systemd/user/desktop-assistant-daemon.service"
  install -Dm644 systemd/org.desktopAssistant.service \
    "${pkgdir}/usr/share/dbus-1/services/org.desktopAssistant.service"
}
